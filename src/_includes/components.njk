{#
  Reusable UI components (Nunjucks macros).
  Import into a template with, e.g.:
    {% from "components.njk" import synergyCard, cardArt, bossArt %}
#}

{# Synergy / partner-archetype card. `rating` is optional (compendium shows it,
   the landing page omits it). Shared by index.njk and cards.njk. #}
{% macro synergyCard(a) %}
<div class="synergy-card">
  <div class="synergy-head">
    <span class="synergy-dot" style="background:{{ a.dot }};"></span>
    <span class="synergy-name">{{ a.name }}</span>
    {% if a.rating %}<span class="synergy-rating">{{ a.rating }}</span>{% endif %}
  </div>
  <div class="synergy-body">{{ a.body }}</div>
</div>
{% endmacro %}

{# Compendium card art: real image when present, else a glyph placeholder. #}
{% macro cardArt(c) %}
<div class="card-art{% if c.image %} has-img{% endif %}">
  {% if c.image %}
  <img class="zoomable" src="{{ c.image | url }}" alt="{{ c.name }}" width="412" height="600" loading="lazy" tabindex="0" role="button" aria-label="View {{ c.name }} full size">
  {% else %}
  <span class="diamond" style="border-color:{{ c.glyphColor }};"><span style="color:{{ c.glyphColor }};">{{ c.glyph }}</span></span>
  <div class="art-caption mono">[ CARD ART ]<br>{{ c.short }}</div>
  <div class="art-stat">{{ c.stat }}</div>
  {% endif %}
</div>
{% endmacro %}

{# Material-cost line for Extra Deck monsters. Label reflects the summon type;
   shared by cards.njk and fiendsmith.njk so the branching lives in one place. #}
{% macro cardCost(c) %}
{% if c.cost %}
{%- if "Xyz" in c.badges %}{% set mt = "xyz" %}{% set ml = "XYZ MATERIAL" %}
{%- elif "Link" in c.badges %}{% set mt = "link" %}{% set ml = "MATERIAL" %}
{%- elif "Synchro" in c.badges %}{% set mt = "synchro" %}{% set ml = "MATERIAL" %}
{%- elif "Fusion" in c.badges %}{% set mt = "fusion" %}{% set ml = "MATERIAL" %}
{%- else %}{% set mt = "generic" %}{% set ml = "MATERIALS" %}{% endif %}
<div class="card-cost"><span class="cost-label cost-{{ mt }}">{{ ml }}</span>{{ c.cost }}</div>{% endif %}
{% endmacro %}

{# Card-group header: dot, title, tag, count. Shared by cards.njk and
   fiendsmith.njk. The parent <details>/id/data-section stays in the page since
   only the compendium filter needs data-section. #}
{% macro groupHead(g) %}
<summary class="group-head">
  <span class="group-dot" style="background:{{ g.dot }};"></span>
  <h2>{{ g.title }}</h2>
  <span class="group-tag">{{ g.tag }}</span>
  <span class="group-count">{{ g.cards | length }}</span>
</summary>
{% endmacro %}

{# The two-column "where it activates" + "tips & tricks" body of a card row.
   Byte-for-byte identical between the two card pages, so it lives here. #}
{% macro cardCols(c) %}
<div class="card-cols">
  <div>
    <div class="col-head zones-head">WHERE IT ACTIVATES</div>
    <div class="zones">
      {% for z in c.zones %}
      <div class="zone-row">
        <span class="zone-pill {{ "zone-hybrid" if "/" in z[0] else "zone-" + (z[0] | lower | replace(' ', '')) }}">{{ z[0] }}</span>
        <span class="zone-text">{{ z[1] }}</span>
      </div>
      {% endfor %}
    </div>
    {% if c.note %}<p class="fs-note">{{ c.note }}</p>{% endif %}
  </div>
  <div class="tips-col">
    <div class="col-head tips-head">TIPS &amp; TRICKS</div>
    <div class="tips">
      {% for tip in c.tips %}
      <div class="tip"><span class="tip-bullet"></span><span>{{ tip | safe }}</span></div>
      {% endfor %}
    </div>
  </div>
</div>
{% endmacro %}

{# Desktop-only hover accordion of the three ritual bosses. Each occupies a
   third at rest; hovering a slice expands it to reveal the full card. Order is
   Murakumo · Habakiri · Futsu so Habakiri sits in the middle. #}
{% macro bossStack(bosses) %}
<div class="boss-stack">
  {% for i in [0, 2, 1] %}
  {% set c = bosses[i] %}
  <a class="boss-slice" href="{{ '/cards/' | url }}#{{ c.id }}" style="background-image:url('{{ c.image | url }}');" aria-label="{{ c.name }}">
    <span class="boss-slice-info">
      <span class="boss-slice-name">{{ c.name }}</span>
      <span class="boss-slice-stat">{{ c.stat }}</span>
    </span>
  </a>
  {% endfor %}
</div>
{% endmacro %}

{# Landing boss-card art: real image when present, else a caption placeholder. #}
{% macro bossArt(c) %}
<div class="boss-art{% if c.image %} has-img{% endif %}">
  {% if c.image %}<img src="{{ c.image | url }}" alt="{{ c.name }}" width="412" height="600" loading="lazy">{% else %}<span class="art-caption mono">[ ART · {{ c.short }} ]</span>{% endif %}
</div>
{% endmacro %}
