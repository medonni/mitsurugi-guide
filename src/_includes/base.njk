<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} · Mitsurugi Ritual Guide</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}">
</head>
<body class="page-{{ nav or 'landing' }}">
  <header class="site-header">
    <a href="{{ '/' | url }}" class="brand">
      <span class="diamond brand-mark"><span>御</span></span>
      <span class="wordmark">MITSURUGI</span>
    </a>
    <button class="nav-toggle" aria-label="Menu" aria-expanded="false" aria-controls="site-nav">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <nav class="nav" id="site-nav">
      <a href="{{ '/' | url }}"{% if nav == 'landing' %} class="active"{% endif %}>Overview</a>
      <a href="{{ '/cards/' | url }}"{% if nav == 'cards' %} class="active"{% endif %}>Cards</a>
      <a href="{{ '/cards/' | url }}#synergy">Synergy</a>
      <a href="{{ '/combos/' | url }}"{% if nav == 'combos' %} class="active"{% endif %}>Combos</a>
      <a href="https://discord.gg/wWpSsNafDT" class="nav-discord" target="_blank" rel="noopener" aria-label="Join our Discord">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.369a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.211.375-.444.864-.608 1.249a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.036A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.1 13.1 0 0 1-1.872-.892.077.077 0 0 1-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.009c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.3 12.3 0 0 1-1.873.891.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.84 19.84 0 0 0 6.002-3.03.077.077 0 0 0 .032-.055c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.028zM8.02 15.331c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
        <span>Discord</span>
      </a>
    </nav>
  </header>

  {{ content | safe }}

  <footer class="site-footer">
    <div class="mono">MITSURUGI RITUAL GUIDE · fan-made resource<br>Card names &amp; effects © Konami, used for reference only.</div>
  </footer>
  <script>
    // Mobile nav toggle. ponytail: one button flips a class + aria; CSS does the rest.
    (function () {
      const btn = document.querySelector(".nav-toggle");
      const nav = document.getElementById("site-nav");
      if (!btn || !nav) return;
      const set = (open) => { nav.classList.toggle("open", open); btn.setAttribute("aria-expanded", open); };
      btn.addEventListener("click", () => set(nav.classList.contains("open") ? false : true));
      nav.addEventListener("click", (e) => { if (e.target.closest("a")) set(false); });
    })();
  </script>
</body>
</html>
