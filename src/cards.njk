---
title: Card Compendium
nav: cards
permalink: /cards/index.html
description: Every Mitsurugi card grouped by where it activates in hand, deck, graveyard, or field, plus the archetype's on-tribute triggers, with tips for real games.
---
{% from "components.njk" import synergyCard, cardArt, cardCost, groupHead, cardCols %}

<section class="container-narrow comp-head">
  <div class="kicker">// CARD COMPENDIUM</div>
  <h1>Every card, by where it activates</h1>
  <p class="intro">Card effects here are simplified and grouped by <em class="em-gold">where they activate</em> (hand, deck, graveyard, or field), plus the archetype's signature on-Tribute triggers. Each entry adds tips &amp; tricks for real games.</p>

  <div class="legend" id="zone-filter">
    <span class="legend-label">WHERE:</span>
    {% for z in cards.zones %}
    <span class="zone-pill zone-{{ z | lower | replace(' ', '') }}" role="button" tabindex="0" data-zone="{{ z | lower | replace(' ', '') }}">{{ z }}</span>
    {% endfor %}
    <span class="note">· tap to filter · the trigger that powers the whole deck</span>
  </div>
</section>

<section class="container-narrow tabs">
  <div class="tabs-row">
    <button class="tab active" data-filter="all">All Cards <span class="count">{{ cards.total }}</span></button>
    {% for g in cards.groups %}
    <button class="tab" data-filter="{{ g.key }}">{{ g.title | replace(" Cards", "") | replace(" Staples", "") }} <span class="count">{{ g.cards | length }}</span></button>
    {% endfor %}
  </div>
</section>

<section class="container-narrow groups">
  {% for g in cards.groups %}
  <details id="{{ g.key }}" class="card-group" data-section="{{ g.key }}" open>
    {{ groupHead(g) }}
    <p class="group-blurb">{{ g.blurb }}</p>

    <div class="card-list">
      {% for c in g.cards %}
      {% if c.label %}<div class="sub-label"><span>{{ c.label }}</span></div>{% endif %}
      <div id="{{ c.id }}" class="card-row" data-zones="{% for z in c.zones %}{{ z[0] | lower | replace(' ', '') | replace('/', ' ') }} {% endfor %}">

        {{ cardArt(c) }}

        <div class="card-content">
          <span class="card-role" style="color:{{ c.glyphColor }};">{{ c.role }}</span>
          <h3>{{ c.name }}</h3>
          <div class="badges">
            {% for b in c.badges %}<span class="badge">{{ b }}</span>{% endfor %}
          </div>
          {{ cardCost(c) }}
          {{ cardCols(c) }}
        </div>
      </div>
      {% endfor %}
    </div>
  </details>
  {% endfor %}

  <p class="filter-empty" id="filter-empty" style="display:none;">
    No cards activate in <span class="filter-empty-zone em-gold"></span>.
    <button type="button" class="filter-reset" id="filter-reset">Clear filter</button>
  </p>

  <details id="synergy" class="card-group" open>
    <summary class="group-head">
      <span class="group-dot" style="background:var(--zone-field);"></span>
      <h2>Expanding into other archetypes</h2>
    </summary>
    <p class="group-blurb">Mitsurugi runs no in-archetype locks, so it welcomes partners. These pair especially well.</p>
    <div class="synergy-grid">
      {% for a in cards.synergy %}
      {{ synergyCard(a) }}
      {% endfor %}
    </div>
    <p class="pending-note mono">More deck variants in progress: {{ cards.synergyPending | join(" · ") }}</p>
  </details>
</section>

<script>
  // ponytail: two independent filter axes (section tabs + zone chips), one apply(). No framework.
  const tabs = document.querySelectorAll(".tab");
  const zoneChips = document.querySelectorAll("#zone-filter .zone-pill");
  const groups = document.querySelectorAll("[data-section]");
  const rows = document.querySelectorAll(".card-row");
  const subLabels = document.querySelectorAll(".sub-label");
  const empty = document.getElementById("filter-empty");
  const emptyZone = empty.querySelector(".filter-empty-zone");
  const state = { section: "all", zone: "all" };

  function apply() {
    rows.forEach((r) => {
      const ok = state.zone === "all" || r.dataset.zones.split(" ").includes(state.zone);
      r.style.display = ok ? "" : "none";
    });
    // sub-label dividers only make sense in the unfiltered functional view
    subLabels.forEach((s) => { s.style.display = state.zone === "all" ? "" : "none"; });
    let anyGroup = false;
    groups.forEach((g) => {
      const okSection = state.section === "all" || g.dataset.section === state.section;
      const hasVisible = !!g.querySelector('.card-row:not([style*="none"])');
      const show = okSection && hasVisible;
      g.style.display = show ? "" : "none";
      if (show) anyGroup = true;
    });
    // no card group survived the filters: explain the blank instead of showing nothing
    if (!anyGroup) {
      const chip = [...zoneChips].find((c) => c.dataset.zone === state.zone);
      emptyZone.textContent = chip ? chip.textContent.trim() : "this zone";
      empty.style.display = "";
    } else {
      empty.style.display = "none";
    }
  }

  tabs.forEach((tab) => tab.addEventListener("click", () => {
    tabs.forEach((t) => t.classList.remove("active"));
    tab.classList.add("active");
    state.section = tab.dataset.filter;
    apply();
  }));

  document.getElementById("filter-reset").addEventListener("click", () => {
    state.section = "all";
    state.zone = "all";
    tabs.forEach((t) => t.classList.toggle("active", t.dataset.filter === "all"));
    zoneChips.forEach((c) => c.classList.remove("active"));
    apply();
  });

  function toggleZone(chip) {
    const z = chip.dataset.zone;
    state.zone = state.zone === z ? "all" : z; // click active chip again to clear
    zoneChips.forEach((c) => c.classList.toggle("active", c.dataset.zone === state.zone));
    apply();
  }
  zoneChips.forEach((chip) => {
    chip.addEventListener("click", () => toggleZone(chip));
    chip.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") { e.preventDefault(); toggleZone(chip); }
    });
  });
</script>
